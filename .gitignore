# =============================================================================
# Dataset files
#
# CSV files outside data/ are ignored by default.
# CSV files inside data/ and its subdirectories are retained.
# =============================================================================
*.csv
*.csv.gz
*.csv.zip

!data/
!data/**/
!data/*.csv
!data/**/*.csv
!data/*.csv.gz
!data/**/*.csv.gz
!data/*.csv.zip
!data/**/*.csv.zip

# Keep documentation files in data/
!data/*.md
!data/**/*.md
!data/*.txt
!data/**/*.txt

